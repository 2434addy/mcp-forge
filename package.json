{
  "name": "@2434addy/mcp-forge",
  "version": "0.3.0",
  "description": "Install, run and manage MCP servers from one cross-platform CLI",
  "type": "module",
  "license": "MIT",
  "bin": {
    "mcp-forge": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').cpSync('src/lib/registry.json','dist/lib/registry.json')\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node tests/e2e-clients.test.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "tui",
    "ink"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "configstore": "^8.0.0",
    "ink": "^7.1.0",
    "ora": "^9.4.1",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "typescript": "^5.9.0"
  }
}
